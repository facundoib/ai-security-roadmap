---
interface Props {
  totalItems: number;
}
const { totalItems } = Astro.props;
---

<div class="progress-tracker" data-total={totalItems}>
  <div class="progress-bar-wrap">
    <div class="progress-bar" id="progress-bar"></div>
  </div>
  <div class="progress-meta">
    <span id="progress-count">0 / {totalItems}</span>
    <button id="progress-reset" type="button">Reset progress</button>
  </div>
</div>

<script is:inline define:vars={{ totalItems }}>
  const KEY = 'ai-security-roadmap-progress-v1';

  function loadState() {
    try {
      const raw = localStorage.getItem(KEY);
      return raw ? JSON.parse(raw) : {};
    } catch {
      return {};
    }
  }

  function saveState(state) {
    try {
      localStorage.setItem(KEY, JSON.stringify(state));
    } catch {}
  }

  function render(state) {
    const items = document.querySelectorAll('.progress-item');
    let done = 0;
    items.forEach((el) => {
      const week = el.getAttribute('data-week');
      const item = el.getAttribute('data-item');
      const key = `w${week}:${item}`;
      const checked = Boolean(state[key]);
      el.checked = checked;
      if (checked) done += 1;
    });
    const bar = document.getElementById('progress-bar');
    const count = document.getElementById('progress-count');
    const pct = totalItems > 0 ? Math.round((done / totalItems) * 100) : 0;
    if (bar) bar.style.width = pct + '%';
    if (count) count.textContent = `${done} / ${totalItems}`;
  }

  function init() {
    const state = loadState();
    render(state);

    document.querySelectorAll('.progress-item').forEach((el) => {
      el.addEventListener('change', (e) => {
        const target = e.currentTarget;
        const week = target.getAttribute('data-week');
        const item = target.getAttribute('data-item');
        const key = `w${week}:${item}`;
        const current = loadState();
        if (target.checked) {
          current[key] = true;
        } else {
          delete current[key];
        }
        saveState(current);
        render(current);
      });
    });

    const reset = document.getElementById('progress-reset');
    if (reset) {
      reset.addEventListener('click', () => {
        if (confirm('Clear all progress?')) {
          localStorage.removeItem(KEY);
          render({});
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
